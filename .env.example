# Groq (Phase 3) — copy to .env and fill in. Never commit .env.
GROQ_API_KEY=
# Optional overrides:
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# GROQ_TEMPERATURE=0.5
# GROQ_MAX_TOKENS=1200
# RECOMMENDER_TOP_K=10  # default list length; capped at 12

# Phase 4 API (optional)
# RECOMMENDER_API_HOST=127.0.0.1
# RECOMMENDER_API_PORT=8000
# RECOMMENDER_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# RECOMMENDER_MAX_CANDIDATES=30
# RECOMMENDER_BUDGET_RELAX_STEP_INR=400
# RECOMMENDER_BUDGET_RELAX_CEILING_INR=250000
